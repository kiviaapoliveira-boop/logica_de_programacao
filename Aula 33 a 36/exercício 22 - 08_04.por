programa {
  funcao inicio() {
      inteiro senhaDigitada 
      inteiro senhaAtual

      escreva("Informe senha diigitada: ")
      leia(senhaDigitada)

      escreva("Informe senha atual: ")
      leia(senhaAtual)

      se (senhaDigitada == senhaAtual) {
        escreva("Acesso Permitido")
      }
  }
}
